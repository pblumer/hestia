{
  "meta": {
    "name": "hestia",
    "version": "0.1.0",
    "note": "SSOT der Design-Tokens (INV-H2). tokens.css + tokens.ts sind generiert. Themenabhängige Werte tragen { light, dark }; alle anderen sind skalar (light == dark)."
  },
  "color": {
    "bg": { "light": "#ffffff", "dark": "#0e1116" },
    "surface": { "light": "#f5f6f8", "dark": "#161b22" },
    "surface-raised": { "light": "#ffffff", "dark": "#1c232c" },
    "overlay": { "light": "rgba(16, 18, 21, 0.45)", "dark": "rgba(0, 0, 0, 0.6)" },
    "fg": { "light": "#1a1d21", "dark": "#e6e8eb" },
    "fg-muted": { "light": "#5a6169", "dark": "#9aa4af" },
    "fg-subtle": { "light": "#8b929b", "dark": "#6b7580" },
    "border": { "light": "#d5d9de", "dark": "#2a313a" },
    "border-strong": { "light": "#b6bcc4", "dark": "#3a434e" },
    "accent": { "light": "#2f6feb", "dark": "#5b8cff" },
    "accent-fg": { "light": "#ffffff", "dark": "#0b1220" },
    "accent-muted": { "light": "#dbe6ff", "dark": "#1d2b4d" },
    "success": { "light": "#1a7f37", "dark": "#3fb950" },
    "success-fg": { "light": "#ffffff", "dark": "#02180a" },
    "warning": { "light": "#9a6700", "dark": "#d29922" },
    "warning-fg": { "light": "#ffffff", "dark": "#1a1300" },
    "danger": { "light": "#cf222e", "dark": "#f85149" },
    "danger-fg": { "light": "#ffffff", "dark": "#1a0202" },
    "info": { "light": "#0969da", "dark": "#58a6ff" },
    "info-fg": { "light": "#ffffff", "dark": "#02121f" },
    "focus-ring": { "light": "#2f6feb", "dark": "#5b8cff" }
  },
  "space": {
    "0": "0",
    "px": "1px",
    "1": "4px",
    "2": "8px",
    "3": "12px",
    "4": "16px",
    "5": "20px",
    "6": "24px",
    "8": "32px",
    "10": "40px",
    "12": "48px",
    "16": "64px"
  },
  "radius": {
    "none": "0",
    "sm": "4px",
    "md": "8px",
    "lg": "12px",
    "xl": "16px",
    "full": "9999px"
  },
  "elevation": {
    "0": { "light": "none", "dark": "none" },
    "1": { "light": "0 1px 2px rgba(16, 18, 21, 0.08)", "dark": "0 1px 2px rgba(0, 0, 0, 0.5)" },
    "2": { "light": "0 2px 6px rgba(16, 18, 21, 0.12)", "dark": "0 2px 8px rgba(0, 0, 0, 0.6)" },
    "3": { "light": "0 8px 24px rgba(16, 18, 21, 0.16)", "dark": "0 10px 30px rgba(0, 0, 0, 0.7)" }
  },
  "text": {
    "family-sans": "system-ui, -apple-system, Segoe UI, Roboto, sans-serif",
    "family-mono": "ui-monospace, SFMono-Regular, Menlo, monospace",
    "size-xs": "12px",
    "size-sm": "13px",
    "size-md": "14px",
    "size-lg": "16px",
    "size-xl": "20px",
    "size-2xl": "28px",
    "weight-regular": "400",
    "weight-medium": "500",
    "weight-semibold": "600",
    "weight-bold": "700",
    "leading-tight": "1.2",
    "leading-normal": "1.5",
    "leading-relaxed": "1.7"
  },
  "motion": {
    "duration-instant": "0ms",
    "duration-fast": "120ms",
    "duration-normal": "200ms",
    "duration-slow": "320ms",
    "ease-standard": "cubic-bezier(0.2, 0, 0, 1)",
    "ease-decelerate": "cubic-bezier(0, 0, 0, 1)",
    "ease-accelerate": "cubic-bezier(0.3, 0, 1, 1)"
  }
}
