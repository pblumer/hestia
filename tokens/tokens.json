{
  "meta": {
    "name": "hestia",
    "version": "0.2.0",
    "themes": ["hestia", "swiss"],
    "default": "hestia",
    "note": "SSOT der Design-Tokens (INV-H2). tokens.css + tokens.ts sind generiert. Ein Token-Wert ist entweder skalar (überall gleich), mode-abhängig { light, dark } (themenneutral) oder theme-abhängig { <theme>: <skalar|{light,dark}> }. Die zwei Achsen sind orthogonal: Theme (Marke: hestia|swiss) über [data-theme], Mode (Hell/Dunkel) über [data-mode] bzw. prefers-color-scheme. Das 'swiss'-Theme reproduziert das Design System der Schweizer Bundesverwaltung (https://swiss.github.io/designsystem); seine Dunkelvariante ist eine abgeleitete Ergänzung (nicht Teil der offiziellen, nur hellen Vorlage)."
  },
  "color": {
    "bg": {
      "hestia": { "light": "#ffffff", "dark": "#0e1116" },
      "swiss": { "light": "#ffffff", "dark": "#131b22" }
    },
    "surface": {
      "hestia": { "light": "#f5f6f8", "dark": "#161b22" },
      "swiss": { "light": "#f9fafb", "dark": "#1c2834" }
    },
    "surface-raised": {
      "hestia": { "light": "#ffffff", "dark": "#1c232c" },
      "swiss": { "light": "#ffffff", "dark": "#263645" }
    },
    "overlay": {
      "hestia": { "light": "rgba(16, 18, 21, 0.45)", "dark": "rgba(0, 0, 0, 0.6)" },
      "swiss": { "light": "rgba(19, 27, 34, 0.5)", "dark": "rgba(0, 0, 0, 0.65)" }
    },
    "fg": {
      "hestia": { "light": "#1a1d21", "dark": "#e6e8eb" },
      "swiss": { "light": "#1f2937", "dark": "#f0f4f7" }
    },
    "fg-muted": {
      "hestia": { "light": "#5a6169", "dark": "#9aa4af" },
      "swiss": { "light": "#6b7280", "dark": "#acb4bd" }
    },
    "fg-subtle": {
      "hestia": { "light": "#8b929b", "dark": "#6b7580" },
      "swiss": { "light": "#9ca3af", "dark": "#828e9a" }
    },
    "border": {
      "hestia": { "light": "#d5d9de", "dark": "#2a313a" },
      "swiss": { "light": "#e5e7eb", "dark": "#2f4356" }
    },
    "border-strong": {
      "hestia": { "light": "#b6bcc4", "dark": "#3a434e" },
      "swiss": { "light": "#d1d5db", "dark": "#46596b" }
    },
    "accent": {
      "hestia": { "light": "#2f6feb", "dark": "#5b8cff" },
      "swiss": { "light": "#d8232a", "dark": "#fc656b" }
    },
    "accent-fg": {
      "hestia": { "light": "#ffffff", "dark": "#0b1220" },
      "swiss": { "light": "#ffffff", "dark": "#131b22" }
    },
    "accent-muted": {
      "hestia": { "light": "#dbe6ff", "dark": "#1d2b4d" },
      "swiss": { "light": "#ffccce", "dark": "#801519" }
    },
    "success": {
      "hestia": { "light": "#1a7f37", "dark": "#3fb950" },
      "swiss": { "light": "#059669", "dark": "#34d399" }
    },
    "success-fg": {
      "hestia": { "light": "#ffffff", "dark": "#02180a" },
      "swiss": { "light": "#ffffff", "dark": "#052e1c" }
    },
    "warning": {
      "hestia": { "light": "#9a6700", "dark": "#d29922" },
      "swiss": { "light": "#d97706", "dark": "#fbbf24" }
    },
    "warning-fg": {
      "hestia": { "light": "#ffffff", "dark": "#1a1300" },
      "swiss": { "light": "#ffffff", "dark": "#231a00" }
    },
    "danger": {
      "hestia": { "light": "#cf222e", "dark": "#f85149" },
      "swiss": { "light": "#d8232a", "dark": "#fc656b" }
    },
    "danger-fg": {
      "hestia": { "light": "#ffffff", "dark": "#1a0202" },
      "swiss": { "light": "#ffffff", "dark": "#131b22" }
    },
    "info": {
      "hestia": { "light": "#0969da", "dark": "#58a6ff" },
      "swiss": { "light": "#2563eb", "dark": "#60a5fa" }
    },
    "info-fg": {
      "hestia": { "light": "#ffffff", "dark": "#02121f" },
      "swiss": { "light": "#ffffff", "dark": "#04121f" }
    },
    "focus-ring": {
      "hestia": { "light": "#2f6feb", "dark": "#5b8cff" },
      "swiss": { "light": "#d8232a", "dark": "#fc656b" }
    }
  },
  "space": {
    "0": "0",
    "px": "1px",
    "1": "4px",
    "2": "8px",
    "3": "12px",
    "4": "16px",
    "5": "20px",
    "6": "24px",
    "8": "32px",
    "10": "40px",
    "12": "48px",
    "16": "64px"
  },
  "radius": {
    "none": "0",
    "sm": { "hestia": "4px", "swiss": "2px" },
    "md": { "hestia": "8px", "swiss": "3px" },
    "lg": { "hestia": "12px", "swiss": "5px" },
    "xl": { "hestia": "16px", "swiss": "6px" },
    "full": "9999px"
  },
  "elevation": {
    "0": { "light": "none", "dark": "none" },
    "1": { "light": "0 1px 2px rgba(16, 18, 21, 0.08)", "dark": "0 1px 2px rgba(0, 0, 0, 0.5)" },
    "2": { "light": "0 2px 6px rgba(16, 18, 21, 0.12)", "dark": "0 2px 8px rgba(0, 0, 0, 0.6)" },
    "3": { "light": "0 8px 24px rgba(16, 18, 21, 0.16)", "dark": "0 10px 30px rgba(0, 0, 0, 0.7)" }
  },
  "text": {
    "family-sans": {
      "hestia": "system-ui, -apple-system, Segoe UI, Roboto, sans-serif",
      "swiss": "'Noto Sans', system-ui, -apple-system, Segoe UI, Roboto, sans-serif"
    },
    "family-mono": "ui-monospace, SFMono-Regular, Menlo, monospace",
    "size-xs": "12px",
    "size-sm": "13px",
    "size-md": "14px",
    "size-lg": "16px",
    "size-xl": "20px",
    "size-2xl": "28px",
    "weight-regular": "400",
    "weight-medium": "500",
    "weight-semibold": "600",
    "weight-bold": "700",
    "leading-tight": "1.2",
    "leading-normal": "1.5",
    "leading-relaxed": "1.7"
  },
  "motion": {
    "duration-instant": "0ms",
    "duration-fast": "120ms",
    "duration-normal": "200ms",
    "duration-slow": "320ms",
    "ease-standard": "cubic-bezier(0.2, 0, 0, 1)",
    "ease-decelerate": "cubic-bezier(0, 0, 0, 1)",
    "ease-accelerate": "cubic-bezier(0.3, 0, 1, 1)"
  }
}
