{
  "name": "@hestia/root",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "tokens": "node tokens/generate.mjs",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint:es": "eslint .",
    "lint:dep": "depcruise web apps --config .dependency-cruiser.cjs",
    "invariants": "node tools/ci/check-invariants.mjs",
    "test": "vitest run",
    "build": "pnpm -r run build"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@hestia/modeler-dmn": "workspace:*",
    "@hestia/modeler-kit": "workspace:*",
    "@hestia/tokens": "workspace:*",
    "@playwright/test": "1.56.0",
    "@types/node": "^22.10.0",
    "dependency-cruiser": "^16.9.0",
    "diagram-js": "^15.19.0",
    "eslint": "^9.17.0",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.19.0",
    "vite": "^8.1.3",
    "vitest": "^3.0.0"
  }
}
